# Clé API Groq pour l'assistant juridique RAG.
# Obtenir une clé (gratuit) : https://console.groq.com/keys
GROQ_API_KEY=

# (Optionnel) Modèle Groq. Défaut : openai/gpt-oss-20b
# Voir les modèles actifs : https://console.groq.com/docs/models
# GROQ_MODEL=openai/gpt-oss-120b

# Secret pour signer les preuves scellées côté serveur (horodatage de confiance).
# Mets une longue valeur aléatoire et garde-la privée.
SCEAU_SECRET=
